{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vite",
    "build": "pnpm run clean && vite build",
    "build:dev": "pnpm run build --config vite.dev.config.ts",
    "clean": "pnpm run rimraf ../cmd/web/assets",
    "lint": "eslint",
    "format:eslint": "eslint '*.cjs' 'src/**/*.{ts,vue}' --fix",
    "format:prettier": "prettier '*.cjs' 'src/**/*.{ts,vue}' --write"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^18.16.19",
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^8.23.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-vue": "^9.4.0",
    "lint-staged": "^13.2.2",
    "prettier": "^2.2.1",
    "rimraf": "^3.0.2",
    "typescript": "~5.1.3",
    "vite": "^8.0.11",
    "vue-tsc": "^0.40.6"
  }
}
