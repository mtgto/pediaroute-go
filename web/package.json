{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite",
    "build": "pnpm run clean && vite build",
    "build:dev": "pnpm run build --config vite.dev.config.ts",
    "clean": "pnpm exec rimraf ../cmd/web/assets",
    "lint": "oxlint src/",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "oxfmt": "latest",
    "oxlint": "latest",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "vite": "^8.0.11",
    "vue-tsc": "^3.2.8"
  }
}
